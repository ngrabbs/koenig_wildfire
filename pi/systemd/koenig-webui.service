[Unit]
Description=Koenig Wildfire web UI
After=network.target koenig-daemon.service
Requires=koenig-daemon.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/code/koenig_wildfire
ExecStart=/usr/bin/python3 -m pi.webui.app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
